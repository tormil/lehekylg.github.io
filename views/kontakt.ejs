    perspective: 800px;    /* Mida väiksem number, seda ekstreemsem 3D efekt */
}

/* 2. Pöörame pilti */
#logo img {
    /* Pitch (rotateX) ja Yaw (rotateY) */
    transform: rotateX(25deg) rotateY(-25deg); 
    
    /* Lisame varju, et rõhutada 2.5D hõljumist */
