<style>
.category-section { margin-bottom: 60px; width: 100%; }
.category-title { font-size: 3em; color: #ff0000; border-bottom: 2px dashed #ff0000; text-transform: uppercase; margin-bottom: 20px; font-family: 'VCR OSD Mono', monospace;}

.liige-grid { display: flex; flex-direction: column; gap: 30px; }
.liige-item { display: flex; align-items: flex-start; gap: 20px; }
.liige-item img { max-width: 300px; height: auto; border: 2px solid #555; }
.liige-item h3 { color: #fff; font-size: 2em; margin: 0; font-family: 'VCR OSD Mono', monospace;}

.carousel-container { display: flex; overflow-x: auto; gap: 15px; padding-bottom: 15px; scroll-snap-type: x mandatory; }
.carousel-container::-webkit-scrollbar { height: 8px; }
.carousel-container::-webkit-scrollbar-thumb { background: #ff0000; border-radius: 4px; }
.carousel-item { flex: 0 0 auto; scroll-snap-align: start; }
.carousel-item img { height: 400px; width: auto; max-width: 90vw; border: 2px solid #555; object-fit: cover; }

.random-shit-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; }
.random-shit-grid img { width: 100%; aspect-ratio: 1/1; object-fit: cover; cursor: pointer; transition: transform 0.2s; border: 1px solid #444; }
.random-shit-grid a:hover img { transform: scale(1.1); z-index: 10; position: relative; border-color: #ff0000; }
@media(max-width: 1024px) { .random-shit-grid { grid-template-columns: repeat(4, 1fr); } }
@media(max-width: 600px) { .random-shit-grid { grid-template-columns: repeat(3, 1fr); } }
</style>

<div style="margin-top: 40px; width: 100%;">
    <% 
        const order = ['Liige', 'Festival', 'Fotoshoot', 'Kontsert', 'Random Shit'];
        const existingCats = typeof categories !== 'undefined' ? Object.keys(categories) : [];
        const sortedCats = existingCats.sort((a,b) => {
            let ia = order.indexOf(a); let ib = order.indexOf(b);
            if(ia===-1) ia = 999; if(ib===-1) ib = 999;
            return ia - ib;
        });
    %>
    
    <% if (sortedCats.length > 0) { %>
        <% sortedCats.forEach(catName => { %>
            <div class="category-section">
                <% if (catName === 'Liige') { %>
                    <div class="liige-grid">
                        <% categories[catName].forEach(photo => { %>
                            <div class="liige-item">
                                <a href="<%= photo.image_url %>" target="_blank">
                                    <img loading="lazy" src="<%= photo.image_url %>" alt="<%= photo.title %>">
                                </a>
                                <h3><%= photo.title || '' %></h3>
                            </div>
                        <% }) %>
                    </div>
                <% } else if (catName === 'Random Shit') { %>
                    <h2 class="category-title"><%= catName %></h2>
                    <div class="random-shit-grid">
                        <% categories[catName].forEach(photo => { %>
                            <a href="<%= photo.image_url %>" target="_blank">
                                <img loading="lazy" src="<%= photo.image_url %>" alt="<%= photo.title %>">
                            </a>
                        <% }) %>
                    </div>
                <% } else { // Festival, Kontsert, Fotoshoot etc %>
                    <h2 class="category-title"><%= catName %></h2>
                    <div class="carousel-container">
                        <% categories[catName].forEach(photo => { %>
                            <div class="carousel-item">
                                <a href="<%= photo.image_url %>" target="_blank">
                                    <img loading="lazy" src="<%= photo.image_url %>" alt="<%= photo.title %>">
                                </a>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        <% }) %>
    <% } else { %>
        <p style="text-align: center; color: #fff;">Galeriisid pole veel lisatud.</p>
    <% } %>
</div>

		
