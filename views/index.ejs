/* KÜLGMÄRGISTE MUUTMINE AINULT KONKREETSEL LEHEL */
.page-id-109 .postarea.full .article {
    padding: 20px; /* Muudab padding-i 20px-ks, säilitades külgedel 12% */
}


/** ma ei m2leta mis siin oli **/

.post-holder, .page-holder, .blog-holder, .archive-holder {
    border: 6px double #ff0000;
}

a, a:link, a:visited {
    color: #ff0000;
}


button {
    /* Tavaline olek */
    color: #FF0000; /* Teksti värv: helepunane */
    border-color: #FF0000; /* Piirjoone värv: helepunane */
    border-style: solid; /* Piirjoone stiil */
    border-width: 1px; /* Piirjoone laius */
    
    /* Lisame üleminekud sujuvaks animatsiooniks */
    transition: all 0.2s ease-in-out; 
    
    /* Mõned esteetilised lisandid nuppudele */
    background-color: transparent; /* Tausta värv: läbipaistev (või vali sobiv) */
    padding: 10px 20px; 
    cursor: pointer; 
    font-size: 16px;
}

button:hover {
    /* Hover (hiire kohal hoidmise) olek */
    color: #B00202; /* Teksti värv: tumedam punane */
    border-color: #B00202; /* Piirjoone värv: tumedam punane */
    border-width: 2px; /* Piirjoone laius: paksem */
}

/* sotssssssssssssssssssssss */

/* Sotsiaalmeedia konteiner header'is */
#social-media-header {
    /* Ujuv paigutus, et olla menüü kõrval */
    float: right; 
}

/* Lingid/nupud ise */
#social-media-header a {
    /* Annab ruumi igale nupule */
    margin-left: 10px; 
    
    /* Tagab, et ikoon oleks nähtav */
    display: inline-block; 
    
    /* Eemaldab vaikimisi lingi allajoonimise */
    text-decoration: none; 
}

/* Font Awesome ikooni stiil */
#social-media-header i {
    /* Ikooni suurus */
    font-size: 24px; 
    
    /* Tavaline ikooni värv */
    color: #444; 
    
    /* Sujuv üleminek hiire kohal hoidmisel */
    transition: color 0.2s ease-in-out; 
}

/* Ikooni värv hiire kohal hoidmisel (HOVER) */
#social-media-header i:hover {
    color: #FF0000; /* Või vali sinu stiiliga sobiv värv */
}

/* Mobiilivaade: paiguta ikoonid navigeerimise alla */
@media screen and (max-width: 599px) {
    #social-media-header {
        float: none;
        width: 100%;
        text-align: center;
        padding: 10px 0;
        border-top: 1px solid #eee;
