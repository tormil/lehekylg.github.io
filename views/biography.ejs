		<style type="text/css" id="wp-custom-css">
			/* 29.01.25 logo 2.5d*/

/* 1. Määrame konteksti (kaamera kauguse) */
#logo a {
    display: inline-block; /* Vajalik, et transformatsioon toimiks korrektselt */
    perspective: 800px;    /* Mida väiksem number, seda ekstreemsem 3D efekt */
}

/* 2. Pöörame pilti */
#logo img {
    /* Pitch (rotateX) ja Yaw (rotateY) */
    transform: rotateX(25deg) rotateY(-25deg); 
    
    /* Lisame varju, et rõhutada 2.5D hõljumist */
    filter: drop-shadow(10px 15px 10px rgba(0,0,0,0.3));

    /* Teeme ülemineku sujuvaks (kui soovid hover efekti) */
    transition: transform 0.4s ease, filter 0.4s ease;
}

/* 3. (Valikuline) Taastame või muudame asendit hiirega peale minnes */
#logo a:hover img {
    transform: rotateX(0deg) rotateY(0deg) scale(1.05);
    filter: drop-shadow(0px 5px 5px rgba(0,0,0,0.2));
}

