}

/* sotssssssssssssssssssssss */

/* Sotsiaalmeedia konteiner header'is */
#social-media-header {
    /* Ujuv paigutus, et olla menüü kõrval */
    float: right; 
}

/* Lingid/nupud ise */
#social-media-header a {
    /* Annab ruumi igale nupule */
    margin-left: 10px; 
    
    /* Tagab, et ikoon oleks nähtav */
    display: inline-block; 
    
    /* Eemaldab vaikimisi lingi allajoonimise */
    text-decoration: none; 
}

/* Font Awesome ikooni stiil */
#social-media-header i {
    /* Ikooni suurus */
    font-size: 24px; 
    
    /* Tavaline ikooni värv */
    color: #444; 
    
    /* Sujuv üleminek hiire kohal hoidmisel */
    transition: color 0.2s ease-in-out; 
}

/* Ikooni värv hiire kohal hoidmisel (HOVER) */
#social-media-header i:hover {
    color: #FF0000; /* Või vali sinu stiiliga sobiv värv */
}

/* Mobiilivaade: paiguta ikoonid navigeerimise alla */
@media screen and (max-width: 599px) {
    #social-media-header {
        float: none;
        width: 100%;
        text-align: center;
        padding: 10px 0;
        border-top: 1px solid #eee;
    }
    #social-media-header a {
        margin: 0 5px;
    }
}


/* poole lühem video wrapper */

/* Sihtige embed konteinerit ja määrake sellele uus kõrgus */
.fluid-width-video-wrapper {
    /* Oluline: alista padding-top reegel, et kõrgust kontrollida */
    padding-top: 0 !important; 
    
    /* Määra uus, lühem kõrgus (vali sobiv väärtus, nt 300px) */
    height: 300px;
    
    /* Tagab, et iframe täidaks selle uue kõrguse */
    overflow: hidden; 
}


/* pildid seinast seina  HETKEL EI TÖÖTA */

/* LAIENDAMINE SEINAST SEINA (kui pilt on endiselt piiratud konteineris) */
/* See kordab ja tugevdab eelmise vastuse koodi, et minna üle vanemate piirangute */
.wp-image-225 {
    width: 55vw !important;
    max-width: 55vw !important;
    
    position: relative !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    
    /* Kasuta marginaale ainult siis, kui left/transform ei tööta */
    /* margin-left: -50vw !important;
    margin-right: -50vw !important; */
}

.seinast-seina {
    width: 100vw;
    max-width: 100vw;
    height: auto;
    
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
}		</style>
		
