button {
    /* Tavaline olek */
    color: #FF0000; /* Teksti värv: helepunane */
    border-color: #FF0000; /* Piirjoone värv: helepunane */
    border-style: solid; /* Piirjoone stiil */
    border-width: 1px; /* Piirjoone laius */
    
    /* Lisame üleminekud sujuvaks animatsiooniks */
    transition: all 0.2s ease-in-out; 
    
    /* Mõned esteetilised lisandid nuppudele */
